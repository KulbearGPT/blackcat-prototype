generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ACTIVE, PAUSED, and SUSPENDED are API-writable; DISABLED is an internal L4 system state.
enum UserStatus {
  ACTIVE
  PAUSED
  SUSPENDED
  DISABLED
}

enum ExternalAccountStatus {
  ACTIVE
  REVOKED
}

enum PlayerReviewStatus {
  PENDING_REVIEW
  ACTIVE
  PAUSED
  SUSPENDED
}

enum PlayerAvailability {
  AVAILABLE
  BUSY
  OFFLINE
}

enum DiscordPresenceStatus {
  ONLINE
  IDLE
  DND
  OFFLINE
  UNKNOWN
}

enum SkillTagType {
  GAME
  SERVICE
  REGION
  LANGUAGE
}

enum StaffLevel {
  L1_SUPPORT
  L2_SUPERVISOR
  L3_OPERATIONS
  L4_ADMIN_OWNER
}

enum StaffAccountStatus {
  ACTIVE
  PENDING_ELEVATION
  SUSPENDED
  DISABLED
}

enum StaffRoleSource {
  DISCORD_ROLE
  MANUAL
  BOOTSTRAP
}

enum RoleSyncStatus {
  APPLIED
  PENDING_ELEVATION
  REJECTED
  DOWNGRADED
  FAILED
}

enum CatalogVersionStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum OrderStatus {
  DRAFT
  PENDING_DISPATCH
  ACCEPTED
  IN_SERVICE
  PENDING_CONFIRMATION
  COMPLETED
  CANCELLED
  EXCEPTION
}

enum OrderEventType {
  CREATED
  DETAILS_UPDATED
  CHANNEL_LINKED
  SUBMITTED
  DISPATCH_STARTED
  DISPATCH_TIMED_OUT
  ACCEPTED
  CUSTOMER_READY_CONFIRMED
  PLAYER_READY_CONFIRMED
  READINESS_RESET
  READINESS_TIMED_OUT
  SERVICE_STARTED
  SERVICE_STARTED_OVERRIDE
  COMPLETION_REQUESTED
  COMPLETED
  CANCELLED
  EXCEPTION_ENTERED
  EXCEPTION_RECOVERED
  RESOLVED
  PANEL_SYNC_REQUESTED
}

enum ResolutionReasonCode {
  USER_REQUEST
  DISPATCH_TIMEOUT
  PLAYER_NO_SHOW
  CUSTOMER_NO_SHOW
  SERVICE_INTERRUPTED
  COMPLETION_DISPUTE
  PAYMENT_FAILURE
  REFUND_FAILURE
  ADMIN_CORRECTION
}

enum DispatchStatus {
  PENDING
  ACTIVE
  ACCEPTED
  TIMED_OUT
  CANCELLED
  FAILED
}

enum DispatchCandidateStatus {
  NOTIFIED
  ACCEPTED
  DECLINED
  EXPIRED
  LOST_RACE
}

enum ExternalTransactionType {
  ORDER_CHARGE
  GIFT_CHARGE
}

/// Original debit mirror lifecycle plus its aggregate refund state.
enum ExternalTransactionStatus {
  UNKNOWN
  PENDING
  SUCCEEDED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

/// Refund execution lifecycle only. Refund aggregation lives on the original ExternalTransaction.
enum RefundStatus {
  UNKNOWN
  PENDING
  SUCCEEDED
  FAILED
}

enum GiftRequestStatus {
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  CAPTURED
  ANNOUNCED
  REJECTED
  EXPIRED
  WITHDRAWN
  FAILED
  REVERSED
}

enum FundReservationSourceType {
  ORDER
  GIFT
}

enum FundReservationMode {
  PROVIDER_NATIVE_HOLD
  LOCAL_RESERVATION_FALLBACK
}

enum FundReservationStatus {
  PENDING
  ACTIVE
  DISPUTED
  PARTIALLY_SETTLED
  CAPTURED
  RELEASED
  EXPIRED
  FAILED
}

enum FundReservationEventType {
  CREATED
  ACTIVATED
  CAPTURED
  RELEASED
  DISPUTED
  DISPUTE_RESOLVED
  EXPIRED
  FAILED
}

enum CancellationPreviewStatus {
  ISSUED
  APPLIED
  EXPIRED
  INVALIDATED
}

enum CancellationDisposition {
  AUTO_RELEASE
  AUTO_REFUND
  STAFF_REVIEW_REQUIRED
  BLOCKED
}

enum StaffTaskType {
  ORDER_ASSIST
  CANCELLATION_ASSIST
  GIFT_REVIEW
  PLAYER_START_LATE
  PLAYER_NO_SHOW
  CUSTOMER_NO_SHOW
  SERVICE_INTERRUPTED
  COMPLETION_REVIEW
  DISPUTE
  AUTOMATION_FAILURE
}

enum StaffTaskStatus {
  OPEN
  CLAIMED
  VERIFIED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RESOLVED
  CANCELLED
}

enum ApprovalAction {
  GIFT_APPROVE
  REFUND_EXECUTE
  ORDER_RESOLVE
  ORDER_REASSIGN
  PLAYER_EARNING_ADJUST
  USER_SUSPEND
  PLAYER_SUSPEND
  CATALOG_CHANGE
  GIFT_CATALOG_CHANGE
  REFERRAL_RULE_CHANGE
  ACCESS_CHANGE
  INTEGRATION_CHANGE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ApprovalDecisionType {
  APPROVE
  REJECT
  CANCEL
}

enum ConsumptionEntryType {
  ORDER_CHARGE
  GIFT_CHARGE
  REFUND_REVERSAL
  ADMIN_CORRECTION
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum PlayerEarningStatus {
  PENDING
  CONFIRMED
  PAID
  REVERSED
}

enum EarningAdjustmentType {
  REVERSAL_DEBIT
  CORRECTION_DEBIT
  CORRECTION_CREDIT
}

enum ReferralProgramType {
  PROMOTER_FIRST_PURCHASE
  PLAYER_LIFETIME
}

enum ReferralProgramVersionStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum ReferralAwardMode {
  FIXED_MINOR
  NET_SPEND_BPS
}

enum ReferralAttributionStatus {
  ACTIVE
  FULFILLED
  SUPERSEDED
  REVOKED
}

enum ReferralAttributionSourceType {
  INVITE_CODE
  ADMIN_MANUAL
  MIGRATED_LEGACY
}

enum CommissionStatus {
  PENDING
  CONFIRMED
  PAID
  REVERSED
}

enum CommissionAdjustmentType {
  REVERSAL_DEBIT
  CORRECTION_DEBIT
  CORRECTION_CREDIT
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum ActorSource {
  DISCORD_BOT
  DASHBOARD
  SYSTEM_JOB
  THIRD_PARTY_WEBHOOK
}

enum BotConfigEventSource {
  DISCORD_BOT
  DASHBOARD
}

enum AuditOutcome {
  SUCCEEDED
  REJECTED
  FAILED
}

enum RiskEventType {
  PLAYER_NO_SHOW
  CUSTOMER_NO_SHOW
  DUPLICATE_ACCOUNT_SIGNAL
  REFERRAL_ABUSE_SIGNAL
  PAYMENT_ANOMALY
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

model User {
  id               String     @id @default(uuid()) @db.Uuid
  displayName      String     @map("display_name") @db.VarChar(100)
  status           UserStatus @default(ACTIVE)
  rowVersion       Int        @default(1) @map("row_version")
  suspendedAt      DateTime?  @map("suspended_at") @db.Timestamptz(3)
  suspensionReason String?    @map("suspension_reason") @db.VarChar(500)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  discordAccounts      DiscordAccount[]
  externalAccounts     ExternalAccount[]
  playerProfile        PlayerProfile?
  staffAccount         StaffAccount?
  customerOrders       Order[]               @relation("OrderCustomer")
  playerOrders         Order[]               @relation("OrderPlayer")
  activeCustomerOrders Order[]               @relation("ActiveOrderCustomer")
  activePlayerOrders   Order[]               @relation("ActiveOrderPlayer")
  acceptedDispatches   DispatchAttempt[]     @relation("DispatchAcceptedPlayer")
  dispatchCandidates   DispatchCandidate[]
  sentGiftRequests     GiftRequest[]         @relation("GiftSender")
  receivedGiftRequests GiftRequest[]         @relation("GiftReceiver")
  externalTransactions ExternalTransaction[]
  refundBeneficiaries  Refund[]              @relation("RefundBeneficiary")
  requestedRefunds     Refund[]              @relation("RefundRequestedByUser")
  consumptionEntries   ConsumptionEntry[]
  fundReservations     FundReservation[]
  fundReservationEvents FundReservationEvent[] @relation("FundReservationEventActorUser")
  fundLocks            UserCurrencyLock[]
  cancellationPreviews CancellationPreview[] @relation("CancellationPreviewRequestedByUser")
  referralBenefits     ReferralAttribution[] @relation("ReferralBeneficiary")
  referralAttributions ReferralAttribution[] @relation("ReferralReferredUser")
  commissions          Commission[]          @relation("CommissionBeneficiary")
  playerEarnings       PlayerEarning[]       @relation("EarningPlayer")
  riskEvents           RiskEvent[]
  idempotencyRecords   IdempotencyRecord[]   @relation("IdempotencyActorUser")
  auditLogs            AuditLog[]            @relation("AuditActorUser")
  orderEvents          OrderEvent[]          @relation("OrderEventActorUser")

  @@index([status])
  @@map("users")
}

model DiscordAccount {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  guildId       String    @map("guild_id") @db.VarChar(32)
  discordUserId String    @map("discord_user_id") @db.VarChar(32)
  username      String?   @db.VarChar(100)
  boundAt       DateTime  @default(now()) @map("bound_at") @db.Timestamptz(3)
  lastSeenAt    DateTime? @map("last_seen_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([guildId, discordUserId])
  @@unique([userId, guildId])
  @@index([userId])
  @@map("discord_accounts")
}

model ExternalAccount {
  id                    String                @id @default(uuid()) @db.Uuid
  userId                String                @map("user_id") @db.Uuid
  provider              String                @db.VarChar(50)
  externalUserId        String                @map("external_user_id") @db.VarChar(255)
  status                ExternalAccountStatus @default(ACTIVE)
  activeUserProviderKey String?               @unique @map("active_user_provider_key") @db.VarChar(350)
  verifiedAt            DateTime              @map("verified_at") @db.Timestamptz(3)
  revokedAt             DateTime?             @map("revoked_at") @db.Timestamptz(3)
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([provider, externalUserId])
  @@index([userId, status])
  @@map("external_accounts")
}

model StaffAccount {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  level              StaffLevel         @default(L1_SUPPORT)
  requestedLevel     StaffLevel?        @map("requested_level")
  status             StaffAccountStatus @default(ACTIVE)
  roleSource         StaffRoleSource    @map("role_source")
  roleSyncedAt       DateTime?          @map("role_synced_at") @db.Timestamptz(3)
  confirmedByStaffId String?            @map("confirmed_by_staff_id") @db.Uuid
  confirmedAt        DateTime?          @map("confirmed_at") @db.Timestamptz(3)
  mfaEnrolled        Boolean            @default(false) @map("mfa_enrolled")
  permissionsVersion Int                @default(1) @map("permissions_version")
  lastLoginAt        DateTime?          @map("last_login_at") @db.Timestamptz(3)
  disabledAt         DateTime?          @map("disabled_at") @db.Timestamptz(3)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                   User                      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  confirmedBy            StaffAccount?             @relation("StaffAccountConfirmation", fields: [confirmedByStaffId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  confirmedStaffAccounts StaffAccount[]            @relation("StaffAccountConfirmation")
  sessions               StaffSession[]
  roleSyncEvents         StaffRoleSyncEvent[]
  approvedPlayerProfiles PlayerProfile[]           @relation("PlayerApprovedBy")
  createdCatalogVersions ServiceCatalogVersion[]   @relation("ServiceVersionCreatedBy")
  createdGiftVersions    GiftCatalogVersion[]      @relation("GiftVersionCreatedBy")
  resolvedOrders         OrderResolution[]         @relation("OrderResolvedBy")
  createdStaffTasks      StaffTask[]               @relation("TaskCreatedBy")
  claimedStaffTasks      StaffTask[]               @relation("TaskClaimedBy")
  resolvedStaffTasks     StaffTask[]               @relation("TaskResolvedBy")
  staffTaskNotes         StaffTaskNote[]
  requestedApprovals     ApprovalRequest[]         @relation("ApprovalRequestedBy")
  approvalDecisions      ApprovalDecision[]        @relation("ApprovalDecidedBy")
  verifiedGiftRequests   GiftRequest[]             @relation("GiftVerifiedBy")
  approvedGiftRequests   GiftRequest[]             @relation("GiftApprovedBy")
  requestedRefunds       Refund[]                  @relation("RefundRequestedByStaff")
  confirmedEarnings      PlayerEarning[]           @relation("EarningConfirmedBy")
  earningAdjustments     PlayerEarningAdjustment[] @relation("EarningAdjustmentCreatedBy")
  cancellationPreviews   CancellationPreview[]     @relation("CancellationPreviewRequestedByStaff")
  fundReservationEvents  FundReservationEvent[]    @relation("FundReservationEventActorStaff")
  referralPrograms       ReferralProgramVersion[]  @relation("ReferralProgramCreatedBy")
  boundAttributions      ReferralAttribution[]     @relation("ReferralAttributionBoundBy")
  commissionAdjustments  CommissionAdjustment[]    @relation("CommissionAdjustmentCreatedBy")
  roleMappingsCreated    DiscordRoleMapping[]      @relation("RoleMappingCreatedBy")
  policyVersionsCreated  PolicySettingVersion[]    @relation("PolicyVersionCreatedBy")
  idempotencyRecords     IdempotencyRecord[]       @relation("IdempotencyActorStaff")
  auditLogs              AuditLog[]                @relation("AuditActorStaff")
  riskEventsCreated      RiskEvent[]               @relation("RiskCreatedBy")
  orderEvents            OrderEvent[]              @relation("OrderEventActorStaff")
  botConfigsUpdated      GuildBotConfig[]           @relation("BotConfigUpdatedBy")
  botConfigEvents        GuildBotConfigEvent[]      @relation("BotConfigEventActor")

  @@index([level, status])
  @@map("staff_accounts")
}

/// One current, schema-validated Bot configuration row per Discord Guild.
model GuildBotConfig {
  guildId          String   @id @map("guild_id") @db.VarChar(32)
  version          Int      @default(1)
  configJson       Json     @map("config_json") @db.JsonB
  updatedByStaffId String   @map("updated_by_staff_id") @db.Uuid
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  updatedBy StaffAccount          @relation("BotConfigUpdatedBy", fields: [updatedByStaffId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  events    GuildBotConfigEvent[]

  @@index([updatedByStaffId, updatedAt])
  @@map("guild_bot_configs")
}

/// Append-only history; application and database roles must reject UPDATE and DELETE.
model GuildBotConfigEvent {
  id                 String               @id @default(uuid()) @db.Uuid
  guildId            String               @map("guild_id") @db.VarChar(32)
  version            Int
  changesJson        Json                 @map("changes_json") @db.JsonB
  previousValuesJson Json                 @map("previous_values_json") @db.JsonB
  reason             String               @db.VarChar(1000)
  actorStaffId       String               @map("actor_staff_id") @db.Uuid
  source             BotConfigEventSource
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  config GuildBotConfig @relation(fields: [guildId], references: [guildId], onDelete: Restrict, onUpdate: Cascade)
  actor  StaffAccount   @relation("BotConfigEventActor", fields: [actorStaffId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([guildId, version])
  @@index([actorStaffId, createdAt])
  @@map("guild_bot_config_events")
}

model StaffSession {
  id                 String    @id @default(uuid()) @db.Uuid
  staffAccountId     String    @map("staff_account_id") @db.Uuid
  sessionHash        String    @unique @map("session_hash") @db.VarChar(128)
  permissionsVersion Int       @map("permissions_version")
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(3)
  stepUpAt           DateTime? @map("step_up_at") @db.Timestamptz(3)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz(3)
  ipHash             String?   @map("ip_hash") @db.VarChar(128)
  userAgentHash      String?   @map("user_agent_hash") @db.VarChar(128)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  staffAccount StaffAccount @relation(fields: [staffAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([staffAccountId, revokedAt, expiresAt])
  @@map("staff_sessions")
}

model DiscordRoleMapping {
  id               String     @id @default(uuid()) @db.Uuid
  guildId          String     @map("guild_id") @db.VarChar(32)
  discordRoleId    String     @map("discord_role_id") @db.VarChar(32)
  targetLevel      StaffLevel @map("target_level")
  version          Int
  enabled          Boolean    @default(true)
  activeMappingKey String?    @unique @map("active_mapping_key") @db.VarChar(80)
  activeLevelKey   String?    @unique @map("active_level_key") @db.VarChar(80)
  createdByStaffId String     @map("created_by_staff_id") @db.Uuid
  retiredAt        DateTime?  @map("retired_at") @db.Timestamptz(3)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  createdBy StaffAccount @relation("RoleMappingCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([guildId, discordRoleId, version])
  @@index([guildId, targetLevel, enabled])
  @@map("discord_role_mappings")
}

model StaffRoleSyncEvent {
  id                     String         @id @default(uuid()) @db.Uuid
  staffAccountId         String?        @map("staff_account_id") @db.Uuid
  guildId                String         @map("guild_id") @db.VarChar(32)
  discordUserId          String         @map("discord_user_id") @db.VarChar(32)
  observedDiscordRoleIds String[]       @map("observed_discord_role_ids")
  mappingVersionSnapshot Json           @map("mapping_version_snapshot") @db.JsonB
  previousLevel          StaffLevel?    @map("previous_level")
  requestedLevel         StaffLevel?    @map("requested_level")
  appliedLevel           StaffLevel?    @map("applied_level")
  status                 RoleSyncStatus
  source                 String         @db.VarChar(50)
  sourceEventId          String         @map("source_event_id") @db.VarChar(200)
  errorCode              String?        @map("error_code") @db.VarChar(100)
  createdAt              DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  staffAccount StaffAccount? @relation(fields: [staffAccountId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([source, sourceEventId])
  @@index([guildId, discordUserId, createdAt])
  @@index([status, createdAt])
  @@map("staff_role_sync_events")
}

model RolePermission {
  level          StaffLevel
  permissionCode String     @map("permission_code") @db.VarChar(100)
  scope          String     @db.VarChar(50)
  policyVersion  Int        @default(1) @map("policy_version")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  @@id([level, permissionCode, scope])
  @@map("role_permissions")
}

model PolicySettingVersion {
  id               String   @id @default(uuid()) @db.Uuid
  key              String   @db.VarChar(100)
  version          Int
  value            Json     @db.JsonB
  currency         String?  @db.Char(3)
  activeSettingKey String?  @unique @map("active_setting_key") @db.VarChar(100)
  createdByStaffId String   @map("created_by_staff_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  createdBy StaffAccount @relation("PolicyVersionCreatedBy", fields: [createdByStaffId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([key, version])
  @@index([key, createdAt])
  @@map("policy_setting_versions")
}

model PlayerProfile {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @unique @map("user_id") @db.Uuid
  reviewStatus       PlayerReviewStatus    @default(PENDING_REVIEW) @map("review_status")
  rowVersion         Int                   @default(1) @map("row_version")
  availability       PlayerAvailability    @default(OFFLINE)
  discordPresence    DiscordPresenceStatus @default(UNKNOWN) @map("discord_presence")
  presenceObservedAt DateTime?             @map("presence_observed_at") @db.Timestamptz(3)
  approvedByStaffId  String?               @map("approved_by_staff_id") @db.Uuid
  approvedAt         DateTime?             @map("approved_at") @db.Timestamptz(3)
  pausedAt           DateTime?             @map("paused_at") @db.Timestamptz(3)
  suspendedAt        DateTime?             @map("suspended_at") @db.Timestamptz(3)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  user       User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  approvedBy StaffAccount? @relation("PlayerApprovedBy", fields: [approvedByStaffId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  skills     PlayerSkill[]

  @@index([reviewStatus, availability, discordPresence])
  @@map("player_profiles")
}

model SkillTag {
  id          String       @id @default(uuid()) @db.Uuid
  type        SkillTagType
  code        String       @db.VarChar(80)
  displayName String       @map("display_name") @db.VarChar(100)
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  playerSkills        PlayerSkill[]
  serviceRequirements ServiceVersionSkillRequirement[]

  @@unique([type, code])
  @@index([enabled, type])
  @@map("skill_tags")
}

model PlayerSkill {
  playerProfileId String   @map("player_profile_id") @db.Uuid
  skillTagId      String   @map("skill_tag_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  skillTag      SkillTag      @relation(fields: [skillTagId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([playerProfileId, skillTagId])
  @@index([skillTagId])
  @@map("player_skills")
}

model ServiceOffering {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique @db.VarChar(100)
  gameCode    String    @map("game_code") @db.VarChar(80)
  gameName    String    @map("game_name") @db.VarChar(100)
  serviceCode String    @map("service_code") @db.VarChar(80)
  serviceName String    @map("service_name") @db.VarChar(100)
  regionCode  String?   @map("region_code") @db.VarChar(80)
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  versions ServiceCatalogVersion[]

  @@unique([gameCode, serviceCode, regionCode])
  @@index([gameCode, archivedAt])
  @@map("service_offerings")
}

model ServiceCatalogVersion {
  id                     String               @id @default(uuid()) @db.Uuid
  serviceOfferingId      String               @map("service_offering_id") @db.Uuid
  version                Int
  status                 CatalogVersionStatus @default(DRAFT)
  activeOfferingKey      String?              @unique @map("active_offering_key") @db.Uuid
  billingUnitMinutes     Int                  @map("billing_unit_minutes")
  minimumUnits           Int                  @map("minimum_units")
  customerUnitPriceMinor BigInt               @map("customer_unit_price_minor")
  playerUnitPayoutMinor  BigInt               @map("player_unit_payout_minor")
  currency               String               @db.Char(3)
