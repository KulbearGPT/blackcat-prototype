model AuditLog {
  id                String       @id @default(uuid()) @db.Uuid
  actorUserId       String?      @map("actor_user_id") @db.Uuid
  actorStaffId      String?      @map("actor_staff_id") @db.Uuid
  actorLevel        StaffLevel?  @map("actor_level")
  actorSource       ActorSource  @map("actor_source")
  clientId          String       @map("client_id") @db.VarChar(80)
  interactionId     String?      @map("interaction_id") @db.VarChar(32)
  permissionCode    String?      @map("permission_code") @db.VarChar(100)
  action            String       @db.VarChar(120)
  targetType        String       @map("target_type") @db.VarChar(80)
  targetId          String       @map("target_id") @db.VarChar(80)
  outcome           AuditOutcome
  beforeSnapshot    Json?        @map("before_snapshot") @db.JsonB
  afterSnapshot     Json?        @map("after_snapshot") @db.JsonB
  reason            String?      @db.VarChar(1000)
  requestId         String       @map("request_id") @db.VarChar(128)
  approvalRequestId String?      @map("approval_request_id") @db.Uuid
  ipHash            String?      @map("ip_hash") @db.VarChar(128)
  userAgentHash     String?      @map("user_agent_hash") @db.VarChar(128)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  actorUser       User?            @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  actorStaff      StaffAccount?    @relation("AuditActorStaff", fields: [actorStaffId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  approvalRequest ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([actorStaffId, createdAt])
  @@index([requestId])
  @@index([interactionId])
  @@index([outcome, createdAt])
  @@map("audit_logs")
}
