  toStatus          FundReservationStatus    @map("to_status")
  amountMinor       BigInt                   @default(0) @map("amount_minor")
  reservationVersion Int                    @map("reservation_version")
  idempotencyKey    String                   @unique @map("idempotency_key") @db.VarChar(200)
  actorUserId       String?                  @map("actor_user_id") @db.Uuid
  actorStaffId      String?                  @map("actor_staff_id") @db.Uuid
