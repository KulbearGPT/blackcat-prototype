model FundReservation {
  id              String                    @id @default(uuid()) @db.Uuid
  userId          String                    @map("user_id") @db.Uuid
  sourceType      FundReservationSourceType @map("source_type")
  orderId         String?                   @unique @map("order_id") @db.Uuid
  giftRequestId   String?                   @unique @map("gift_request_id") @db.Uuid
  mode            FundReservationMode
  provider        String?                   @db.VarChar(50)
  providerHoldRef String?                   @map("provider_hold_ref") @db.VarChar(255)
  amountMinor     BigInt                    @map("amount_minor")
  currency        String                    @db.Char(3)
  status          FundReservationStatus     @default(PENDING)
  rowVersion      Int                       @default(1) @map("row_version")
  idempotencyKey  String                    @unique @map("idempotency_key") @db.VarChar(200)
  expiresAt       DateTime?                 @map("expires_at") @db.Timestamptz(3)
  activatedAt     DateTime?                 @map("activated_at") @db.Timestamptz(3)
  settledAt       DateTime?                 @map("settled_at") @db.Timestamptz(3)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                 User                       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  order                Order?                     @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  giftRequest          GiftRequest?               @relation(fields: [giftRequestId], references: [id], onDelete: Restrict, onUpdate: Cascade)
